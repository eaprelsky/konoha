[Unit]
Description=Claude Agent Kakashi (Bug Fixer)
After=network.target redis.service
Wants=claude-watchdog-kakashi.service
After=claude-watchdog-kakashi.service

[Service]
Type=simple
User=ubuntu
ExecStart=/home/ubuntu/scripts/claude-kakashi-service.sh
Restart=always
MemoryMax=800M
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
