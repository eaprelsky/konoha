[Unit]
Description=Claude Watchdog Inojin (Konoha SSE → tmux)
After=network.target redis.service claude-inojin.service

[Service]
Type=simple
User=ubuntu
EnvironmentFile=/home/ubuntu/.agent-env
ExecStart=/usr/bin/python3 /home/ubuntu/scripts/watchdog-inojin.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
