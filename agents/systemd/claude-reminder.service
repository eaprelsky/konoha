[Unit]
Description=Claude Reminder Service (Redis scheduler + Konoha → Sasuke)
After=network.target redis.service konoha.service
Wants=redis.service konoha.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu
EnvironmentFile=/home/ubuntu/.agent-env
ExecStart=/usr/bin/python3 /home/ubuntu/scripts/reminder-service.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
