[Unit]
Description=Claude Agent Ibiki (Security Pentester) — on-demand
After=network.target redis.service

[Service]
Type=simple
User=ubuntu
ExecStart=/home/ubuntu/scripts/claude-ibiki-service.sh
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
